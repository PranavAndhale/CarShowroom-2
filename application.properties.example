# Database Settings
db.url=jdbc:mysql://localhost:3306/car_showroom
db.user=root
db.password=YOUR_MYSQL_PASSWORD_HERE

# Application Settings
app.name=AutoElite Management System
app.version=1.0.0
app.debug=true
